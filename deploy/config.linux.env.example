# ========== Linux 统一入口配置 ==========
# 复制为 deploy/config.env（Linux 上通常由 ecosystem.linux.config.cjs 覆盖大部分项）
# 文档: docs/deploy-linux.md

MT5_BIND_HOST=0.0.0.0
MT5_TCP_PORT=9627
MT5_HTTP_PORT=9628

MT5_TRADE_ENABLED=1
MT5_TRADE_MODE=router
MT5_ACCOUNT_MAP=/opt/mt5_project/deploy/accounts.json
MT5_REQUIRE_ACCOUNT_ID=1
MT5_BACKEND_PROBE_MS=3000

# 可选：/rpc/* 鉴权
# MT5_GATEWAY_API_KEY=change-me-in-production
# MT5_GATEWAY_IP_WHITELIST=1.2.3.4
