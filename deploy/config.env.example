# ========== Linux 统一入口（行情 + 账户路由）==========
MT5_BIND_HOST=0.0.0.0
MT5_TCP_PORT=9627
MT5_HTTP_PORT=9628
MT5_TRADE_ENABLED=1
MT5_TRADE_MODE=router
MT5_ACCOUNT_MAP=/opt/mt5_project/deploy/accounts.json
MT5_REQUIRE_ACCOUNT_ID=1
MT5_GATEWAY_API_KEY=change-me-in-production
# MT5_GATEWAY_IP_WHITELIST=1.2.3.4,5.6.7.8

# ========== Windows Python 桥接 → Linux 行情 ==========
MT5_PATH=E:\workspace\服务器\MT5\terminal64.exe
MT5_TCP_HOST=43.99.61.45
MT5_SYMBOLS=XAUUSD,XAGUSD,USDCNH
MT5_POLL_MS=200

# ========== Windows 本机交易网关（local 模式）==========
# Linux 用 router；Windows 用 local
MT5_TRADE_MODE=local
MT5_TRADE_BIND_HOST=127.0.0.1
MT5_TRADE_PORT=9530
MT5_TRADE_URL=http://127.0.0.1:9530
MT5_TRADE_MAGIC=880001
MT5_TRADE_DEVIATION=20

# 账户映射见 deploy/accounts.json.example
