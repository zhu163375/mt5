# ========== 远程 Windows 部署配置 ==========
# 复制为 deploy/config.env 后修改
# 文档: docs/deploy-remote-windows.md

# --- Node 网关 ---
# local 模式：本机处理 /rpc/*，再转发到 Python 9530
# Linux router 需访问本机时设为 0.0.0.0，并配置防火墙仅允许 Linux IP
MT5_BIND_HOST=0.0.0.0
MT5_TCP_PORT=9627
MT5_HTTP_PORT=9628

# --- 行情 bridge → Linux ---
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_TCP_HOST=43.99.61.45
MT5_SYMBOLS=XAUUSD,XAGUSD,USDCNH
MT5_POLL_MS=200

# --- 交易（Python 仅本机，勿暴露公网）---
MT5_TRADE_ENABLED=1
MT5_TRADE_MODE=local
MT5_TRADE_BIND_HOST=127.0.0.1
MT5_TRADE_PORT=9530
MT5_TRADE_URL=http://127.0.0.1:9530
MT5_TRADE_MAGIC=880001
MT5_TRADE_DEVIATION=20
