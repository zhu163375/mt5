{
  "name": "mt5-quotes",
  "version": "1.0.0",
  "description": "从 MetaTrader 5 获取实时行情（Node.js + Python/EA 桥接）",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/start-server.js",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1",
  "show-ea": "powershell -ExecutionPolicy Bypass -File scripts/show-ea-folder.ps1",
    "boot": "powershell -ExecutionPolicy Bypass -File scripts/start.ps1",
    "auto": "powershell -ExecutionPolicy Bypass -File scripts/start-auto.ps1",
    "status": "powershell -ExecutionPolicy Bypass -File scripts/status.ps1",
    "bridge": "powershell -ExecutionPolicy Bypass -File deploy/windows/start-bridge.ps1",
    "install:win": "powershell -ExecutionPolicy Bypass -File deploy/windows/install.ps1",
    "trade": "powershell -ExecutionPolicy Bypass -File deploy/windows/start-trade.ps1",
    "trade:test": "node examples/test-trade-readonly.js",
    "pm2:linux": "pm2 start ecosystem.linux.config.cjs",
    "pm2:win": "pm2 start ecosystem.config.cjs --only mt5-quotes,mt5-bridge,mt5-trade",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "quote": "node examples/get-quote.js",
    "stream": "node examples/stream-quotes.js"
  },
  "engines": {
    "node": ">=18"
  }
}
