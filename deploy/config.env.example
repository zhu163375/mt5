# ========== Linux 行情服务 ==========
# 监听地址：Linux 生产环境用 0.0.0.0，本机开发用 127.0.0.1
MT5_BIND_HOST=0.0.0.0
MT5_TCP_PORT=9527
MT5_HTTP_PORT=9528

# ========== Windows Python 桥接 ==========
# MT5 程序路径（Windows）
MT5_PATH=E:\workspace\服务器\MT5\terminal64.exe

# 行情推送目标：Linux 服务器 IP（不是 127.0.0.1）
MT5_TCP_HOST=43.99.61.45

# 推送品种（逗号分隔，与券商一致）
MT5_SYMBOLS=XAUUSD,EURUSD,USDCNH

# 轮询间隔毫秒
MT5_POLL_MS=200
